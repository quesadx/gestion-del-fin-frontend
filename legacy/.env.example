# Gestión del Fin — Frontend Environment Variables
# Copy this file to .env.local and fill in the actual values

# API Base URL (default: local development server)
VITE_API_URL=http://localhost:3000/api

# Application Display Name
VITE_APP_NAME=Gestión del Fin

# Session Timeout in milliseconds (20 minutes = 1200000ms)
VITE_SESSION_TIMEOUT_MS=1200000
