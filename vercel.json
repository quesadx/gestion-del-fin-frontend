{
  "framework": "vite",
  "buildCommand": "pnpm run build",
  "outputDirectory": "dist",
  "installCommand": "pnpm install --frozen-lockfile",
  "rewrites": [
    {
      "source": "/api-remote/(.*)",
      "destination": "https://gestion-del-fin-api-production.up.railway.app/api/$1"
    },
    {
      "source": "/api/(.*)",
      "destination": "https://gestion-del-fin-api-production.up.railway.app/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
